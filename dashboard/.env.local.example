# GitHub API access, used to commit edits back to data/inventory.json and data/sold.json
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username
GITHUB_REPO=sofi-ticket-desk
GITHUB_BRANCH=master

# Password required to view/use the dashboard
APP_PASSWORD=choose-a-password

# Random string used to sign session cookies — any long random value works
SESSION_SECRET=generate-a-long-random-string
